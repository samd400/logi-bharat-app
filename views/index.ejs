                <div class="bg-white rounded-xl border p-4 text-center">
                    <p class="text-2xl font-bold text-yellow-600">₹3,600</p>
                    <p class="text-xs text-gray-500 mt-1">Pending Payout</p>
                </div>
            </div>
            <div class="bg-white rounded-xl border p-6">
                <h4 class="font-bold text-gray-800 mb-4">Transaction History</h4>
                <div class="space-y-2">
                    ${txns.map(t => `<div class="flex items-center justify-between p-3 rounded-lg hover:bg-gray-50 transition">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-full flex items-center justify-center ${t.type === 'credit' ? 'bg-green-100' : 'bg-red-100'}">
                                <span>${t.type === 'credit' ? '↓' : '↑'}</span>
                            </div>
                            <div><p class="text-sm font-medium text-gray-800">${t.desc}</p><p class="text-xs text-gray-400">${t.date}</p></div>
                        </div>
                        <p class="font-bold ${t.type === 'credit' ? 'text-green-600' : 'text-red-500'}">${t.amount}</p>
                    </div>`).join('')}
                </div>
            </div>
        </div>`;
}

// ============================================================
// LOAD FORM + AI PRICE ESTIMATOR
// ============================================================
document.getElementById('load-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const body = {
        origin: fd.get('origin'), destination: fd.get('destination'),
        weight: fd.get('weight'),
        dimensions: { l: fd.get('dim_l'), w: fd.get('dim_w'), h: fd.get('dim_h') },
        load_type: fd.get('load_type'), mode: fd.get('mode'),
        is_green: fd.get('is_green') === 'on',
        needs_insurance: fd.get('needs_insurance') === 'on',
    };
    const result = await api('/loads', 'POST', body);
    state.activeLoadId = result.load_id;
    document.getElementById('bids-placeholder').classList.add('hidden');
    document.getElementById('bids-section').classList.remove('hidden');
    document.getElementById('bids-container').innerHTML = '';
    if (state.bidInterval) clearInterval(state.bidInterval);
    simulateBids(state.activeLoadId);
});

async function getAIPriceEstimate() {
    const fd = new FormData(document.getElementById('load-form'));
    const body = { origin: fd.get('origin'), destination: fd.get('destination'), weight: fd.get('weight'), load_type: fd.get('load_type') };
    const btn = event.currentTarget;
    btn.textContent = 'Estimating...';
    btn.disabled = true;
    try {
        const data = await api('/ai/estimate-price', 'POST', body);
        const el = document.getElementById('ai-price-result');
        document.getElementById('ai-price-range').textContent = `₹${data.min_price.toLocaleString('en-IN')} – ₹${data.max_price.toLocaleString('en-IN')}`;
        document.getElementById('ai-price-note').textContent = `Suggested: ₹${data.suggested_price.toLocaleString('en-IN')} · ${data.reasoning}`;
        document.getElementById('ai-carbon-info').innerHTML = `🌫️ Diesel: ~${data.carbon_kg} kg CO₂ &nbsp;|&nbsp; 🌿 EV: ~${data.ev_carbon_kg} kg CO₂ (${Math.round((1 - data.ev_carbon_kg/data.carbon_kg)*100)}% less)`;
        el.classList.remove('hidden');
    } catch(e) { showToast('Could not get estimate', 'error'); }
    btn.innerHTML = `<svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>AI Estimate`;
    btn.disabled = false;
}

async function simulateBids(loadId) {
    const drivers = [
        { driver_id: 1, name: 'Raju Singh', vehicle: 'Tata Ultra T.16', base: 1.0 },
        { driver_id: 2, name: 'Mani Logistics', vehicle: 'Eicher Pro 2095', base: 1.05 },
        { driver_id: 3, name: 'Deepak Transports', vehicle: 'Ashok Leyland Ecomet', base: 0.97 },
        { driver_id: 4, name: 'Green Mile EV', vehicle: 'Tata Ace EV 🌿', base: 1.08 },
    ];
    let i = 0;
    state.bidInterval = setInterval(async () => {
        if (i >= drivers.length) { clearInterval(state.bidInterval); return; }
        const d = drivers[i++];
        const price = Math.round(17000 * d.base / 100) * 100;
        await api('/bids', 'POST', { load_id: loadId, driver_id: d.driver_id, price });
        const { bids } = await api(`/loads/${loadId}`);
        renderBids(bids);
    }, 1800);
}

function renderBids(bids) {
    document.getElementById('bids-container').innerHTML = bids.sort((a, b) => b.value_score - a.value_score).map(b => {
        const v = JSON.parse(b.vehicle_details || '{}');
        return `<div class="border rounded-xl p-4 flex items-center gap-4 fade-in hover:shadow-md transition">
            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center font-bold text-blue-700 flex-shrink-0">${b.name[0]}</div>
            <div class="flex-1 min-w-0">
                <p class="font-bold text-gray-800">${b.name}</p>
                <p class="text-xs text-gray-500">${v.vehicle || 'Vehicle'}</p>
                <div class="flex gap-2 mt-1">
                    <span class="text-xs bg-green-100 text-green-700 font-semibold px-2 py-0.5 rounded-full">🤖 Value: ${b.value_score}</span>
                    ${b.rating ? `<span class="text-xs text-yellow-600">★ ${b.rating}</span>` : ''}
                </div>
            </div>
            <div class="text-right flex-shrink-0">
                <p class="font-bold text-xl text-blue-700">₹${b.price.toLocaleString('en-IN')}</p>
                <button onclick="acceptBid(${b.load_id}, ${b.id}, ${b.driver_id})" class="mt-1 bg-green-600 text-white text-xs font-bold py-1.5 px-3 rounded-lg hover:bg-green-700">Accept</button>
            </div>
        </div>`;
    }).join('');
}

async function acceptBid(load_id, bid_id, driver_id) {
    await api('/trips/start', 'PUT', { load_id, bid_id, driver_id });
    if (state.bidInterval) clearInterval(state.bidInterval);
    showToast('Bid accepted! Trip is now in-transit.', 'success');
    navigateTo('tracking');
}

// ============================================================
// AI CHAT
// ============================================================
function toggleAIChat() {
    document.getElementById('ai-chat-panel').classList.toggle('hidden');
}

function sendQuickChat(msg) {
    document.getElementById('chat-input').value = msg;
    sendChat();
}

async function sendChat() {
    const input = document.getElementById('chat-input');
    const msg = input.value.trim();
    if (!msg) return;
    input.value = '';
    const messagesEl = document.getElementById('chat-messages');
    messagesEl.innerHTML += `<div class="chat-msg-user"><p class="text-sm">${escapeHtml(msg)}</p></div>`;
    messagesEl.innerHTML += `<div id="typing-indicator" class="chat-msg-ai"><p class="text-sm text-gray-400">Logi-AI is thinking...</p></div>`;
    messagesEl.scrollTop = messagesEl.scrollHeight;
    state.chatHistory.push({ role: 'user', content: msg });
    try {
        const data = await api('/ai/chat', 'POST', { message: msg, history: state.chatHistory.slice(-8) });
        document.getElementById('typing-indicator')?.remove();
        messagesEl.innerHTML += `<div class="chat-msg-ai"><p class="text-sm">${escapeHtml(data.reply)}</p></div>`;
        state.chatHistory.push({ role: 'assistant', content: data.reply });
    } catch {
        document.getElementById('typing-indicator')?.remove();
        messagesEl.innerHTML += `<div class="chat-msg-ai"><p class="text-sm text-red-500">Connection error. Please try again.</p></div>`;
    }
    messagesEl.scrollTop = messagesEl.scrollHeight;
}

// ============================================================
// MISC
// ============================================================
function triggerSOS() {
    if (confirm('🚨 Send SOS alert? Your location and trip details will be shared with emergency contacts and Logi-Bharat support.')) {
        showToast('SOS sent! Support is on the way.', 'error');
    }
}

function showToast(msg, type = 'success') {
    const t = document.createElement('div');
    const colors = { success: 'bg-green-600', error: 'bg-red-600', info: 'bg-blue-600' };
    t.className = `fixed top-6 right-6 ${colors[type]} text-white px-5 py-3 rounded-xl shadow-lg z-50 text-sm font-semibold fade-in`;
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3000);
}

function escapeHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
}

// ============================================================
// INIT
// ============================================================
window.onload = () => switchPerspective('shipper');
</script>
