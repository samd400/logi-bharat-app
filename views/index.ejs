            </div>
            <div class="text-right">
                <span class="text-xs font-bold text-purple-700 bg-purple-100 px-2 py-1 rounded-lg">🤖 ${match}% match</span>
            </div>
        </div>
        <div class="flex gap-2 flex-wrap mb-4">
            <span class="badge badge-blue">${l.load_type || 'General'}</span>
            <span class="badge badge-gray">${l.weight} T</span>
