async function placeBid(loadId) {
    const price = prompt('Enter your bid amount in ₹ (e.g., 18000):');
    if (!price || isNaN(price)) return;
    await api('/bids', 'POST', { load_id: loadId, driver_id: 1, price: parseFloat(price) });
    showToast('Bid placed successfully!', 'success');
    navigateTo('find-loads');
}

