        </div>

        <div id="app-content" class="flex-1 p-6 overflow-y-auto">

            <!-- SHIPPER: Dashboard -->
            <div id="dashboard-view" class="view fade-in"></div>

            <!-- SHIPPER: Post a Load -->
            <div id="post-load-view" class="view fade-in">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-1 bg-white p-6 rounded-xl shadow-sm border">
                        <h3 class="text-lg font-bold mb-4 text-gray-800">Shipment Details</h3>
                        <form id="load-form" class="space-y-4">
                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Origin</label>
                                <input type="text" name="origin" value="Bangalore, KA" placeholder="Origin city" class="mt-1 block w-full bg-gray-50 border border-gray-200 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            </div>
                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Destination</label>
                                <input type="text" name="destination" value="Chennai, TN" placeholder="Destination city" class="mt-1 block w-full bg-gray-50 border border-gray-200 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            </div>
                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Weight (Tonnes)</label>
                                <input type="number" name="weight" value="10" placeholder="Weight" class="mt-1 block w-full bg-gray-50 border border-gray-200 rounded-lg p-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            </div>
                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Dimensions (optional)</label>
                                <div class="grid grid-cols-3 gap-2 mt-1">
                                    <input type="number" name="dim_l" placeholder="L (ft)" class="block w-full bg-gray-50 border border-gray-200 rounded-lg p-2.5 text-sm">
                                    <input type="number" name="dim_w" placeholder="W (ft)" class="block w-full bg-gray-50 border border-gray-200 rounded-lg p-2.5 text-sm">
                                    <input type="number" name="dim_h" placeholder="H (ft)" class="block w-full bg-gray-50 border border-gray-200 rounded-lg p-2.5 text-sm">
                                </div>
                            </div>
                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Type of Load</label>
                                <select name="load_type" class="mt-1 block w-full bg-gray-50 border border-gray-200 rounded-lg p-2.5 text-sm">
                                    <option>General Goods</option>
                                    <option selected>Textiles & Apparel</option>
                                    <option>Electronics</option>
                                    <option>Industrial Parts</option>
                                    <option>Perishables (Refrigerated)</option>
                                    <option>Construction Materials</option>
                                </select>
                            </div>
                            <fieldset>
                                <legend class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Logistics Mode</legend>
                                <div class="flex gap-3 mt-2">
                                    <label class="flex items-center gap-2 p-2.5 border rounded-lg cursor-pointer has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500 text-sm flex-1">
                                        <input type="radio" name="mode" value="road" checked> Road
                                    </label>
                                    <label class="flex items-center gap-2 p-2.5 border rounded-lg cursor-pointer has-[:checked]:bg-blue-50 has-[:checked]:border-blue-500 text-sm flex-1">
                                        <input type="radio" name="mode" value="multimodal"> Multi-Modal
                                    </label>
                                </div>
                            </fieldset>
                            <fieldset>
                                <legend class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Options</legend>
                                <div class="space-y-2 mt-2">
                                    <label class="flex items-center gap-2 p-2.5 border rounded-lg cursor-pointer has-[:checked]:bg-green-50 has-[:checked]:border-green-500 text-sm">
                                        <input type="checkbox" name="is_green"> 🌿 Request EV/CNG Vehicle
                                    </label>
                                    <label class="flex items-center gap-2 p-2.5 border rounded-lg cursor-pointer has-[:checked]:bg-yellow-50 has-[:checked]:border-yellow-500 text-sm">
                                        <input type="checkbox" name="needs_insurance"> 🛡️ Add Per-Trip Insurance (₹450)
                                    </label>
                                </div>
                            </fieldset>

                            <!-- AI Price Estimator -->
                            <div id="ai-price-result" class="hidden bg-purple-50 border border-purple-200 rounded-lg p-3">
                                <p class="text-xs font-bold text-purple-700 mb-1">🤖 AI Price Intelligence</p>
                                <p id="ai-price-range" class="text-lg font-bold text-purple-900"></p>
                                <p id="ai-price-note" class="text-xs text-purple-600 mt-1"></p>
                                <div id="ai-carbon-info" class="mt-2 pt-2 border-t border-purple-200 text-xs text-gray-600"></div>
                            </div>

                            <div class="flex gap-2">
