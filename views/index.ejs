                                <button type="submit" class="flex-1 bg-blue-600 text-white font-bold py-2.5 px-4 rounded-lg hover:bg-blue-700 text-sm flex items-center justify-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                                    Find Truck
                                </button>
                            </div>
                        </form>
                    </div>

                    <div id="bids-placeholder" class="lg:col-span-2 bg-white p-8 rounded-xl shadow-sm border flex flex-col items-center justify-center text-center">
                        <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                            <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>
                        <p class="text-gray-500 font-medium">Post a load to receive live bids from verified drivers.</p>
                        <p class="text-gray-400 text-sm mt-1">Use AI Estimate first to know the fair market rate.</p>
                    </div>

                    <div id="bids-section" class="lg:col-span-2 bg-white p-6 rounded-xl shadow-sm border hidden">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-bold text-gray-800">Live Bids</h3>
                            <span class="text-xs bg-green-100 text-green-700 font-semibold px-3 py-1 rounded-full animate-pulse">Receiving bids...</span>
                        </div>
                        <div id="bids-container" class="space-y-3"></div>
                    </div>
                </div>
            </div>

            <!-- SHIPPER: Tracking -->
            <div id="tracking-view" class="view fade-in"></div>

            <!-- SHIPPER: Warehouses -->
            <div id="warehouses-view" class="view fade-in"></div>

            <!-- SHIPPER: Documents -->
            <div id="documents-view" class="view fade-in"></div>

            <!-- DRIVER: Dashboard -->
            <div id="driver-dashboard-view" class="view fade-in"></div>

            <!-- DRIVER: Find Loads -->
            <div id="find-loads-view" class="view fade-in"></div>

            <!-- DRIVER: Trucker's Hub -->
            <div id="trucker-hub-view" class="view fade-in"></div>

            <!-- DRIVER: Wallet -->
            <div id="wallet-view" class="view fade-in"></div>
