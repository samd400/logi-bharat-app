function initTrackingMap(trips) {
    if (state.maps['tracking-map']) state.maps['tracking-map'].remove();
    const map = L.map('tracking-map').setView([18.5, 78.5], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
    // Simulate truck positions
    const positions = [[12.97, 77.6], [13.08, 80.27], [18.96, 72.82], [28.7, 77.1]];
    positions.slice(0, trips.length || 2).forEach((pos, i) => {
        const trip = trips[i];
        L.marker(pos, {
            icon: L.divIcon({ html: '<div class="truck-marker">🚛</div>', className: '', iconSize: [28, 28] })
        }).addTo(map).bindPopup(trip ? `<b>${trip.origin} → ${trip.destination}</b><br>${trip.driver_name}` : 'Active truck');
    });
    state.maps['tracking-map'] = map;
}

