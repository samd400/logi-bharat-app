<!-- Driver FABs -->
<div id="driver-fabs" class="hidden fixed bottom-6 right-24 flex flex-col gap-3 z-10">
    <button onclick="alert('Voice command: (Demo) Say your destination or bid amount.')" class="bg-white p-4 rounded-full shadow-lg text-blue-600 hover:bg-gray-100 border" title="Voice Command">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
    </button>
    <button onclick="triggerSOS()" class="bg-red-600 text-white p-4 rounded-full shadow-lg hover:bg-red-700" title="SOS Emergency">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
    </button>
</div>

<!-- AI Chat Panel -->
<div id="ai-chat-panel" class="hidden fixed bottom-6 right-6 w-96 bg-white rounded-2xl shadow-2xl border z-20 flex flex-col" style="height: 520px;">
    <div class="bg-purple-600 text-white p-4 rounded-t-2xl flex items-center justify-between flex-shrink-0">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-white/20 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            </div>
            <div>
                <p class="font-bold text-sm">Logi-AI Assistant</p>
                <p class="text-purple-200 text-xs">Logistics expert · Always available</p>
            </div>
        </div>
        <button onclick="toggleAIChat()" class="text-white/70 hover:text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3">
        <div class="chat-msg-ai">
            <p class="text-sm">👋 Hi! I'm <strong>Logi-AI</strong>, your logistics expert. Ask me about pricing, routes, documentation, or green logistics!</p>
        </div>
        <div class="flex flex-wrap gap-2 mt-2">
            <button onclick="sendQuickChat('What are the current freight rates?')" class="quick-chat-btn">💰 Freight rates</button>
            <button onclick="sendQuickChat('How do I create an e-Waybill?')" class="quick-chat-btn">📄 E-Waybill help</button>
            <button onclick="sendQuickChat('Tell me about EV/green logistics')" class="quick-chat-btn">🌿 Green logistics</button>
        </div>
    </div>
    <div class="p-3 border-t flex-shrink-0">
        <div class="flex gap-2">
            <input id="chat-input" type="text" placeholder="Ask anything about logistics..." class="flex-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent" onkeydown="if(event.key==='Enter') sendChat()">
            <button onclick="sendChat()" class="bg-purple-600 text-white px-3 py-2 rounded-lg hover:bg-purple-700">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            </button>
        </div>
    </div>
</div>

<script>
// ============================================================
// STATE
// ============================================================
let state = {
    perspective: 'shipper',
    activeView: 'dashboard',
    activeLoadId: null,
    maps: {},
    chatHistory: [],
    bidInterval: null,
};

// ============================================================
// API HELPER
// ============================================================
async function api(endpoint, method = 'GET', body = null) {
    const opts = { method, headers: { 'Content-Type': 'application/json' } };
    if (body) opts.body = JSON.stringify(body);
    const r = await fetch(`/api${endpoint}`, opts);
    if (!r.ok) throw new Error(`API ${endpoint} failed: ${r.status}`);
    return r.json();
}

// ============================================================
// NAVIGATION
// ============================================================
const STATIC_VIEWS = ['post-load'];

function switchPerspective(p) {
    state.perspective = p;
    document.getElementById('shipper-nav').classList.toggle('hidden', p !== 'shipper');
    document.getElementById('driver-nav').classList.toggle('hidden', p !== 'driver');
    document.getElementById('driver-fabs').classList.toggle('hidden', p !== 'driver');
    document.getElementById('shipper-btn').classList.toggle('active', p === 'shipper');
    document.getElementById('driver-btn').classList.toggle('active', p === 'driver');
    navigateTo(p === 'shipper' ? 'dashboard' : 'driver-dashboard');
}

function navigateTo(view) {
    state.activeView = view;
    document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
    const link = [...document.querySelectorAll('.sidebar-item')].find(el => el.getAttribute('onclick')?.includes(`'${view}'`));
    if (link) link.classList.add('active');
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    const el = document.getElementById(`${view}-view`);
    if (!el) return;
    el.classList.add('active');
    document.getElementById('view-title').textContent = link ? link.querySelector('span')?.textContent : 'Dashboard';

    if (!STATIC_VIEWS.includes(view)) {
        el.innerHTML = '<div class="flex items-center justify-center h-40"><div class="loader"></div></div>';
        renderViewContent(view, el);
    }
}

async function renderViewContent(view, container) {
    try {
        switch (view) {
            case 'dashboard':          await renderShipperDashboard(container); break;
            case 'tracking':           await renderTracking(container); break;
            case 'warehouses':         await renderWarehouses(container); break;
            case 'documents':          renderDocuments(container); break;
            case 'driver-dashboard':   await renderDriverDashboard(container); break;
            case 'find-loads':         await renderFindLoads(container); break;
            case 'trucker-hub':        await renderTruckerHub(container); break;
            case 'wallet':             renderWallet(container); break;
        }
    } catch (e) {
        container.innerHTML = `<div class="text-red-500 p-4">Error loading view. <button onclick="navigateTo('${view}')" class="underline">Retry</button></div>`;
    }
}

