        <div id="driver-nav" class="flex-grow p-2 overflow-y-auto hidden">
            <p class="text-xs font-semibold text-gray-400 uppercase px-3 pt-3 pb-1">Driver</p>
            <a href="#" onclick="navigateTo('driver-dashboard')" class="sidebar-item flex items-center space-x-3 p-3 rounded-lg text-gray-700 hover:bg-gray-100">
